geom_point()+
facet_wrap(~plot)
ggplot(daily_temps,aes(x=date,y=meanT,color=aspect))+
geom_point()+
facet_wrap(~plot)
ggplot(daily_temps,aes(x=date,y=highT,color=aspect))+
geom_point()+
facet_wrap(~plot)
ggplot(daily_temps,aes(x=date,y=lowT,color=aspect))+
geom_point()+
facet_wrap(~plot)
